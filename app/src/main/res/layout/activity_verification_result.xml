<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/backgroundColor">

    <TextView
        android:id="@+id/txtResultTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verification Result"
        android:background="@color/backgroundColor"
        android:textSize="28sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/imgStatus"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="30dp"
        android:src="@android:drawable/checkbox_on_background"
        android:background="@color/backgroundColor"/>

    <TextView
        android:id="@+id/txtCandidateName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:text="Candidate Name : John Doe"
        android:background="@color/backgroundColor"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/txtApplicationNo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Application No : APP001"
        android:background="@color/backgroundColor"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/txtDepartment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Department : Computer Engineering"
        android:background="@color/backgroundColor"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="VERIFIED"
        android:background="@color/backgroundColor"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBackDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Back To Dashboard"
        android:background="@color/backgroundColor"/>

</LinearLayout>