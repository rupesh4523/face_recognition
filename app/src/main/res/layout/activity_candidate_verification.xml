<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="25dp"
        android:paddingEnd="25dp"
        android:paddingBottom="25dp"
        android:paddingTop="80dp">

        <!-- Logo -->

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="end"
            android:adjustViewBounds="true"
            android:background="@android:color/transparent"
            android:padding="-200dp"
            android:src="@drawable/profile"
            android:scaleType="fitCenter"/>

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginTop="50dp"
            android:src="@mipmap/ic_launcher" />

        <!-- App Name -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:text="AttendX"
            android:textColor="@color/textPrimary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <!-- Subtitle -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="25dp"
            android:text="Face Recognition Attendance System"
            android:textColor="@color/textPrimary"
            android:textSize="14sp" />

        <!-- Verify Candidate -->

        <Button
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="10dp"
            android:text="🔍 Verify Candidate"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Register Candidate -->

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="15dp"
            android:text="➕ Register Candidate"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Candidate List -->

        <Button
            android:id="@+id/btnCandidateList"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="15dp"
            android:text="📋 Candidate List"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Profile -->


        <!-- Dashboard Info -->

        <TextView
            android:id="@+id/txtDashboardInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:text="Welcome Admin"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Version -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:text="Version 1.0"
            android:textColor="@color/textPrimary"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>